# Messaging Service - Environment Variables
# These are set in docker-compose.yml but can be overridden via .env file

# =============================================================================
# KAFKA CONFIGURATION
# =============================================================================

# Kafka bootstrap servers (internal Docker network)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Topic to consume inventory changes from
KAFKA_TOPIC=inventory-changes

# Consumer group ID (must be unique per service)
KAFKA_CONSUMER_GROUP=messaging-service

# Dead Letter Queue topic for failed messages
KAFKA_DLQ_TOPIC=inventory-changes.DLQ

# Topic for employee review events
KAFKA_REVIEWS_TOPIC=employee-reviews

# Consumer group for review processing
# KAFKA_CONSUMER_GROUP_REVIEWS=messaging-service-reviews

# =============================================================================
# SLACK CONFIGURATION
# =============================================================================

# Incoming webhook URL for alerts (required)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Bot token for Slack API (required for advanced features)
SLACK_TOKEN=xoxb-your-slack-bot-token

# Channel for inventory alerts
SLACK_CHANNEL=#inventory-alerts

# Enable/disable Slack notifications
SLACK_ENABLED=true

# Channel for employee review notifications
REVIEW_SLACK_CHANNEL=#piggly-review

# =============================================================================
# ALERT CONFIGURATION
# =============================================================================

# Debounce period to prevent duplicate alerts (seconds)
ALERT_DEBOUNCE_SECONDS=300

# Low stock threshold for locations (items below this trigger alert)
LOCATION_LOW_STOCK_THRESHOLD=5

# Recovery threshold - must reach this level to clear alert (hysteresis)
LOCATION_LOW_STOCK_RECOVERY=7

# Slack delivery poll interval (seconds)
NOTIFICATION_POLL_INTERVAL=5.0

# =============================================================================
# REVIEW SCRAPING CONFIGURATION
# =============================================================================

# Hour to fetch reviews daily (0-23, in UTC)
REVIEW_FETCH_HOUR=6

# Maximum reviews to fetch per run
REVIEW_MAX_REVIEWS=25

# =============================================================================
# SUPABASE (for reading inventory data)
# =============================================================================

# These are inherited from root .env via docker-compose env_file
# SUPABASE_URL=https://PROJECTID.supabase.co
# SUPABASE_SERVICE_ROLE=your-service-role-key
