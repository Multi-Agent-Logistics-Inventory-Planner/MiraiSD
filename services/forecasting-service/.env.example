# Forecasting Service - Environment Variables
# These are set in docker-compose.yml but can be overridden via .env file

# =============================================================================
# KAFKA CONFIGURATION
# =============================================================================

# Kafka bootstrap servers (internal Docker network)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Topic to consume inventory changes from
KAFKA_TOPIC=inventory-changes

# Consumer group ID (must be unique per service)
KAFKA_CONSUMER_GROUP=forecasting-service

# Dead Letter Queue topic for failed messages
KAFKA_DLQ_TOPIC=inventory-changes.DLQ

# =============================================================================
# KAFKA CONSUMER TUNING (Advanced)
# =============================================================================

# Minimum bytes to fetch per request
# KAFKA_FETCH_MIN_BYTES=1

# Max records per poll
# KAFKA_MAX_POLL_RECORDS=500

# Session timeout in milliseconds
# KAFKA_SESSION_TIMEOUT_MS=30000

# Heartbeat interval in milliseconds
# KAFKA_HEARTBEAT_INTERVAL_MS=10000

# =============================================================================
# BATCHING CONFIGURATION
# =============================================================================

# Max time to wait before processing a batch (seconds)
BATCH_WINDOW_SECONDS=30

# Process immediately if batch reaches this size
BATCH_SIZE_TRIGGER=50

# Dedupe rapid updates to same item within this window (seconds)
ITEM_DEBOUNCE_SECONDS=5.0

# =============================================================================
# FORECASTING ALGORITHM PARAMETERS
# =============================================================================

# Forecast horizon in days
# TARGET_DAYS=21

# Rolling window for demand calculation (days)
# ROLLING_WINDOW=14

# Exponential smoothing alpha (0-1)
# ES_ALPHA=0.3

# Minimum mean demand floor
# MU_FLOOR=0.1

# Minimum standard deviation floor
# SIGMA_FLOOR=0.01

# Default service level target (0-1)
# SERVICE_LEVEL_DEFAULT=0.95

# Default lead time standard deviation (days)
# LEAD_TIME_STD_DEFAULT_DAYS=0.0

# Epsilon for mean calculation
# EPSILON_MU=0.1

# =============================================================================
# SUPABASE (for writing forecasts)
# =============================================================================

# These are inherited from root .env via docker-compose env_file
# SUPABASE_URL=https://PROJECTID.supabase.co
# SUPABASE_SERVICE_ROLE=your-service-role-key
