# Mirai Inventory System - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# SUPABASE (Required)
# =============================================================================

# PostgreSQL connection string (pooler mode recommended for production)
SUPABASE_DB_URL=jdbc:postgresql://db.PROJECTID.supabase.co:5432/postgres

# Database credentials
SUPABASE_DB_USERNAME=postgres.PROJECTID
SUPABASE_DB_PASSWORD=your-database-password

# JWT secret for token validation (Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=your-jwt-secret

# Service role key for admin operations (Settings > API > Service Role)
SUPABASE_SERVICE_ROLE=your-service-role-key

# Project URL and anon key (Settings > API)
SUPABASE_URL=https://PROJECTID.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# SLACK (Required for alerts)
# =============================================================================

# Incoming webhook URL for inventory alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Bot token for Slack API (xoxb-...)
SLACK_TOKEN=xoxb-your-slack-bot-token

# Default channel for inventory alerts
SLACK_CHANNEL=#inventory-alerts

# Enable/disable Slack notifications
SLACK_ENABLED=true

# =============================================================================
# EXTERNAL SERVICES (Required)
# =============================================================================

# EasyPost API key for shipment tracking
EASYPOST_API_KEY=your-easypost-api-key

# Resend API key for email notifications
RESEND_API_KEY=your-resend-api-key

# Apify credentials for review scraping (optional)
APIFY_API_TOKEN=your-apify-token
APIFY_ACTOR_ID=your-apify-actor-id
GOOGLE_PLACE_URL=https://www.google.com/maps/place/your-business

# =============================================================================
# CORS & SECURITY
# =============================================================================

# Frontend URL for CORS (production Vercel URL)
CORS_ALLOWED_ORIGIN=https://your-app.vercel.app

# Rate limiting (requests per minute per IP)
RATE_LIMIT_REQUESTS=250

# =============================================================================
# KAFKA (Optional - defaults provided)
# =============================================================================

# Bootstrap servers (internal Docker network)
# KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Topics
# KAFKA_TOPIC=inventory-changes
# KAFKA_DLQ_TOPIC=inventory-changes.DLQ
# KAFKA_REVIEWS_TOPIC=employee-reviews

# =============================================================================
# ALERTS (Optional - defaults provided)
# =============================================================================

# Alert debounce in seconds (prevent spam)
# ALERT_DEBOUNCE_SECONDS=300

# Low stock thresholds
# LOCATION_LOW_STOCK_THRESHOLD=5
# LOCATION_LOW_STOCK_RECOVERY=7

# =============================================================================
# REVIEW SCRAPING (Optional - defaults provided)
# =============================================================================

# Channel for employee review notifications
# REVIEW_SLACK_CHANNEL=#piggly-review

# Hour to fetch reviews daily (0-23)
# REVIEW_FETCH_HOUR=6

# Max reviews to fetch per run
# REVIEW_MAX_REVIEWS=25

# =============================================================================
# FRONTEND (Optional - set at build time)
# =============================================================================

# These are typically set via Vercel environment variables
# NEXT_PUBLIC_SUPABASE_URL=https://PROJECTID.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_BACKEND_URL=https://api.your-domain.com
# INVITATION_REDIRECT_URL=https://your-app.vercel.app/auth/callback
